{
  "expo": {
    "name": "Threadoria",
    "slug": "threadoria",
    "owner": "shivom1010",
    "version": "2.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/threadoria-logo.png",
    "scheme": "threadoria",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "updates": {
      "url": "https://u.expo.dev/shivom1010",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.threadoria.boutique"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/threadoria-logo.png",
        "backgroundColor": "#FDF6E9"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.threadoria.boutique"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/threadoria-logo.png",
      "name": "Threadoria - Stitched with Love",
      "shortName": "Threadoria",
      "description": "Stitched with Love, Created by Sisters - Premium boutique management app",
      "backgroundColor": "#FDF6E9",
      "themeColor": "#8B4513",
      "startUrl": "/",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/threadoria-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FDF6E9"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
