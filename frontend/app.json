{
  "expo": {
    "name": "MAAHIS",
    "slug": "maahis",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/maahis-logo.png",
    "scheme": "maahis",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maahis.boutique"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/maahis-logo.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.maahis.boutique"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/maahis-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/maahis-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
